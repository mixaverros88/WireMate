DATA_PATH=${USERPROFILE}\docker_volumes\wiremate

# GitHub Container Registry — must be your GitHub org/user, lowercase.
# Images are published by .github/workflows/docker-publish.yml.
GHCR_OWNER=mixaverros88

# Image tag to pull. Use "latest" to track main, or pin to a commit
# (e.g. main-abc1234 / sha-abc1234) for reproducible deploys.
IMAGE_TAG=latest