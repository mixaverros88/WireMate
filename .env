# Data volumes path
DATA_PATH=${HOME:-${USERPROFILE}}/docker_volumes/wiremate

# Postgres
POSTGRES_IMAGE=postgres:17-alpine
DB_HOST=postgres
DB_PORT=5432
DB_NAME=wiremate
DB_USER=wiremate
DB_PASSWORD=wiremate

# WireMock
WIREMOCK_IMAGE=wiremock/wiremock:3.13.2
WIREMOCK_PORT=9000

# need it here for the APP_CORS_ORIGINS
UI_PORT=9002

# Backend
BACKEND_IMAGE=ghcr.io/mixaverros88/wiremate-service:latest
BACKEND_PORT=9001
APP_WIREMOCK_BASE_URL=http://wiremock:8080
APP_WIREMOCK_MAIN_PATH=/__admin/mappings
APP_CROSS_CHECK_INTERVAL=10000
APP_CROSS_CHECK_ENABLED=false
APP_CORS_ORIGINS=http://localhost:${UI_PORT}

# UI
UI_IMAGE=ghcr.io/mixaverros88/wiremate-ui:latest
UI_WIREMOCK_URL=http://localhost:${WIREMOCK_PORT}/__admin
UI_WIREMATE_BASE_URL=http://localhost:${BACKEND_PORT}